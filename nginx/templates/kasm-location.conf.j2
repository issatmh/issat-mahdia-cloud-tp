{# Jinja2 template — généré par lancer_kasm.sh / lancer_windows.sh #}
{# Variables: container_name, port, type (linux|windows) #}

{% if type == "windows" %}
location = /kasm/{{ container_name }}/ {
    return 302 /kasm/{{ container_name }}/vnc.html?autoconnect=true&cursor=local&quality=2&compression=7&resize=scale&path=kasm/{{ container_name }}/websockify;
}
{% else %}
location = /kasm/{{ container_name }}/ {
    return 302 /kasm/{{ container_name }}/vnc_auto.html?autoconnect=true&reconnect=true&reconnect_delay=1000&resize=scale&quality=6&path=kasm/{{ container_name }}/websockify;
}
{% endif %}

location ^~ /kasm/{{ container_name }}/websockify {
    proxy_pass http://127.0.0.1:{{ port }}/websockify;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
    proxy_buffering off;
}

location ^~ /kasm/{{ container_name }}/ {
    proxy_pass http://127.0.0.1:{{ port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
    proxy_buffering off;
}
