server {
    listen 80;
    server_name labo.issat.local;

    # Portail SSO Authentik (page de login et portail TP)
    location / {
        proxy_pass http://127.0.0.1:9000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Redirecteur Flask — lancement de TP et redirection bureau
    location /bureau       { proxy_pass http://127.0.0.1:8080; proxy_set_header Cookie $http_cookie; }
    location /lancer-tp/   { proxy_pass http://127.0.0.1:8080; proxy_set_header Cookie $http_cookie; }

    # Auth interne (utilisée par auth_request — anti-usurpation de session)
    location = /auth-kasm {
        internal;
        proxy_pass http://127.0.0.1:8080/auth-kasm;
        proxy_set_header X-Original-URI $request_uri;
        proxy_set_header Cookie $http_cookie;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
    }

    # Bureaux virtuels — chaque /kasm/{container}/ est protégé par auth_request
    location ^~ /kasm/ {
        auth_request /auth-kasm;
        error_page 401 = @login;
        error_page 403 = @forbidden;
        include /etc/nginx/kasm-locations/*.conf;
    }

    location @login     { return 302 http://labo.issat.local; }
    location @forbidden { return 403 "Accès refusé."; }
}
