# Authentik SSO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles (ne jamais committer .env)

# PostgreSQL
PG_DB=authentik
PG_USER=authentik
PG_PASS=CHANGE_ME_strong_random_password

# Authentik
# Générer avec: python3 -c "import secrets; print(secrets.token_hex(50))"
AUTHENTIK_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_50

# Redis (si Redis séparé, sinon Authentik utilise son Redis interne)
# AUTHENTIK_REDIS__HOST=redis

# Email (optionnel — pour les notifications)
# AUTHENTIK_EMAIL__HOST=smtp.example.com
# AUTHENTIK_EMAIL__PORT=587
# AUTHENTIK_EMAIL__USE_TLS=true
# AUTHENTIK_EMAIL__USERNAME=noreply@example.com
# AUTHENTIK_EMAIL__PASSWORD=CHANGE_ME
# AUTHENTIK_EMAIL__FROM=noreply@example.com
