[Unit]
Description=Webhook Receiver Labo Kasm — Flask service (port 9001)
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=docker
WorkingDirectory=/home/docker/authentik
ExecStart=/usr/bin/python3 /home/docker/authentik/webhook_receiver.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
